###############################################################################
# Environment file for GEOS-Chem Classic using GCC and a Spack environment
#
# This file loads the Spack environment that contains:
#   - hdf5~mpi
#   - netcdf-c~mpi
#   - netcdf-fortran~mpi
#   - zlib
#   - other dependencies built inside the ncf-env Spack environment
#
# IMPORTANT:
#   This file loads the environment. It does NOT update or rebuild packages.
###############################################################################

# Display message if interactive shell
if [[ $- = *i* ]] ; then
  echo "Loading GEOS-Chem Classic environment (Spack-based)..."
fi

#==============================================================================
# Initialize Spack (only if not already initialized)
#==============================================================================

if [[ -z "${SPACK_ROOT}" ]]; then
    source /home/bryan/spack/share/spack/setup-env.sh
fi

#==============================================================================
# Activate the Spack environment containing the correct NetCDF stack
#==============================================================================

spack env activate ncf-env

if [[ $- = *i* ]] ; then
  echo "... Spack environment 'ncf-env' activated"
fi

#==============================================================================
# Load additional tools needed for GEOS-Chem Classic
#==============================================================================

#spack load flex
#spack load cdo%gcc
#spack load nco%gcc

#==============================================================================
# Compiler settings
#==============================================================================

export CC=gcc
export CXX=g++
export FC=gfortran
export F77=gfortran

#==============================================================================
# NetCDF paths (non-MPI versions from ncf-env)
#==============================================================================

export NETCDF_HOME=$(spack location -i netcdf-c%gcc)
export NETCDF_LIB=${NETCDF_HOME}/lib

export NETCDF_FORTRAN_HOME=$(spack location -i netcdf-fortran%gcc)
export NETCDF_FORTRAN_LIB=${NETCDF_FORTRAN_HOME}/lib

#==============================================================================
# Flex (for KPP)
#==============================================================================

#export FLEX_HOME=$(spack location -i flex%gcc)
#export KPP_FLEX_LIB_DIR=${FLEX_HOME}/lib

#==============================================================================
# OpenMP settings
#==============================================================================

umask 022
export OMP_NUM_THREADS=16
export OMP_STACKSIZE="1900m"

#==============================================================================
# System limits
#==============================================================================

ulimit -c unlimited
ulimit -u 50000
ulimit -v unlimited
ulimit -s unlimited

#==============================================================================
# Print summary
#==============================================================================

echo ""
echo "Environment summary:"
echo "CC                  : ${CC}"
echo "CXX                 : ${CXX}"
echo "FC                  : ${FC}"
echo "NETCDF_HOME         : ${NETCDF_HOME}"
echo "NETCDF_FORTRAN_HOME : ${NETCDF_FORTRAN_HOME}"
echo "KPP_FLEX_LIB_DIR    : ${KPP_FLEX_LIB_DIR}"
echo "OMP_NUM_THREADS     : ${OMP_NUM_THREADS}"
echo ""
echo "Done sourcing ${BASH_SOURCE[0]}"
echo "Note: This file loads modules but does not update them."
